{
  "name": "prepmap-api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "import:students": "node ./scripts/import_students.mjs",
    "seed:super-students": "node ./scripts/seed_super_students.mjs",
    "db:ensure-timestamps": "node ./scripts/ensure_timestamps.mjs",
    "export:csv-all": "node ./scripts/export_all_tables_csv.mjs",
    "copy:db": "node ./scripts/copy_db_to_db.mjs",
    "copy:storage": "node ./scripts/copy_supabase_bucket.mjs",
    "refactor:content-model": "node ./scripts/refactor_content_model.mjs",
    "cleanup:legacy-content": "node ./scripts/drop_legacy_content_tables.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-cloud/storage": "^7.19.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "dotenv": "^16.6.1",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "multer": "^2.1.1",
    "pdfjs-dist": "4.10.38",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
