# Required
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
PORT=4000
JWT_SECRET=replace-with-a-strong-random-secret

# Optional auth tuning
JWT_ACCESS_TTL_SECONDS=900

# Supabase Storage (recommended)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=prepmap-files

# AI generation
# Supported values: anthropic | openai
AI_PROVIDER=anthropic
# If not set, defaults by provider:
# - anthropic -> claude-sonnet-4-5
# - openai -> gpt-5-mini
AI_MODEL=
AI_REQUEST_INTERVAL_MS=3500
LOW_QUOTA_MODE=false
QUESTION_BATCH_SIZE=35
QUESTION_MIN_BATCH_SIZE=10

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime flags
NODE_ENV=development
LOG_LEVEL=info
API_BODY_LIMIT=25mb
SKIP_DB_INIT=false
ALLOW_START_WITHOUT_DB_INIT=false
PGPOOL_MAX=3
PGPOOL_IDLE_TIMEOUT_MS=10000
PGPOOL_CONNECTION_TIMEOUT_MS=5000
