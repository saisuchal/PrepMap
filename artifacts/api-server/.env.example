# Required
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
PORT=4000

# Supabase Storage (alternative to Object Storage; recommended if using Supabase-only)
# When these are set, upload/generation file pipeline will use Supabase storage paths (/supabase/...).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=prepmap-files

# AI generation (provider switch)
# Supported values: anthropic | openai
AI_PROVIDER=anthropic
# If not set, defaults by provider:
# - anthropic -> claude-sonnet-4-5
# - openai -> gpt-5-mini
AI_MODEL=
# Optional global throttle between AI requests in milliseconds
# (set 0 to disable local throttle)
AI_REQUEST_INTERVAL_MS=3500
# Optional low-quota generation mode
LOW_QUOTA_MODE=false
# Question-bank tuning
# Question/star targets are derived from exam type:
# - mid1/mid2 -> 50 questions, 20 starred
# - endsem -> 75 questions, 25 starred
QUESTION_BATCH_SIZE=35
QUESTION_MIN_BATCH_SIZE=10

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key
# Optional if using a custom proxy/base url
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional Replit-compatible names
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_key
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://...

# OpenAI
OPENAI_API_KEY=your_openai_key
# Optional custom base URL (OpenAI-compatible proxy/gateway)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional
NODE_ENV=development
LOG_LEVEL=info
# Max incoming JSON/form payload size (used by Lane B import and large admin payloads)
API_BODY_LIMIT=25mb
