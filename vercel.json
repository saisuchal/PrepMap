{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter prepmap-exam-roadmap run build",
  "outputDirectory": "artifacts/exam-roadmap/dist/public",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 60
    }
  }
}
